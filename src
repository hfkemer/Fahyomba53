import { useEffect, useState } from 'react';
import { supabase } from '../App';
import { BarChart3, Mail, RotateCw } from 'lucide-react';

export default function AdminPanel() {
  const [users, setUsers] = useState<any[]>([]);
  const [tasks, setTasks] = useState<any[]>([]);
  const [logs, setLogs] = useState<any[]>([]);
  const [isLoading, setIsLoading] = useState(true);
  const [resetingUserId, setResetingUserId] = useState<string | null>(null);

  useEffect(() => {
    loadData();
  }, []);

  const loadData = async () => {
    try {
      const [usersRes, tasksRes, logsRes] = await Promise.all([
        supabase.from('users').select('*'),
        supabase.from('tasks').select('*'),
        supabase.from('activity_logs').select('*').order('timestamp', { ascending: false }).limit(50),
      ]);

      if (usersRes.error) throw usersRes.error;
      if (tasksRes.error) throw tasksRes.error;
      if (logsRes.error) throw logsRes.error;

      setUsers(usersRes.data || []);
      setTasks(tasksRes.data || []);
      setLogs(logsRes.data || []);
    } catch (error) {
      console.error('Error loading admin data:', error);
    } finally {
      setIsLoading(false);
    }
  };

  const handlePasswordReset = async (userId: string, userEmail: string, userName: string) => {
    setResetingUserId(userId);

    try {
      const response = await fetch(
        `${import.meta.env.VITE_SUPABASE_URL}/functions/v1/reset_password`,
        {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Authorization: `Bearer ${import.meta.env.VITE_SUPABASE_ANON_KEY}`,
          },
          body: JSON.stringify({
            userId,
            userEmail,
            userName,
          }),
        }
      );

      const data = await response.json();

      if (data.success) {
        alert(`Şifre sıfırlama bağlantısı ${userEmail} adresine gönderildi`);
      } else {
        alert('Hata: ' + data.error);
      }
    } catch (error) {
      console.error('Password reset error:', error);
      alert('Şifre sıfırlama sırasında hata oluştu');
    } finally {
      setResetingUserId(null);
    }
  };

  const completedTasks = tasks.filter((t) => t.status === 'completed').length;

  return (
    <div className="bg-white/10 backdrop-blur-2xl rounded-2xl p-8 border border-white/20">
      <h3 className="text-3xl font-semibold mb-8 flex items-center gap-3">
        <BarChart3 className="w-8 h-8" />
        Admin Kontrol Paneli
      </h3>

      {isLoading ? (
        <div className="text-center py-12">
          <div className="inline-block w-8 h-8 border-4 border-slate-600 border-t-blue-500 rounded-full animate-spin"></div>
        </div>
      ) : (
        <>
          <div className="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
            <div className="bg-white/10 border border-white/20 rounded-lg p-6 text-center">
              <p className="text-white/60 text-sm font-medium">Toplam Kullanıcı</p>
              <p className="text-5xl font-bold text-white mt-3">{users.length}</p>
            </div>
            <div className="bg-white/10 border border-white/20 rounded-lg p-6 text-center">
              <p className="text-white/60 text-sm font-medium">Toplam Görev</p>
              <p className="text-5xl font-bold text-white mt-3">{tasks.length}</p>
            </div>
            <div className="bg-white/10 border border-white/20 rounded-lg p-6 text-center">
              <p className="text-white/60 text-sm font-medium">Tamamlanan Görev</p>
              <p className="text-5xl font-bold text-green-400 mt-3">{completedTasks}</p>
            </div>
          </div>

          <div className="mb-10">
            <h4 className="text-2xl font-semibold mb-4 text-white">
              Kullanıcılar (Ad, E-posta, Rol)
            </h4>
            <div className="bg-white/10 border border-white/20 rounded-lg overflow-hidden max-h-96 overflow-y-auto">
              <div className="divide-y divide-white/10">
                {users.map((user) => (
                  <div key={user.id} className="p-4 hover:bg-white/5 transition-colors">
                    <div className="flex items-center justify-between gap-4">
                      <div className="flex-1">
                        <p className="text-white font-medium">{user.name}</p>
                        <p className="text-white/60 text-sm">
                          {user.email || 'E-posta yok'} • Rol: {user.role}
                        </p>
                      </div>
                      {user.role !== 'admin' && (
                        <button
                          onClick={() =>
                            handlePasswordReset(user.id, user.email || user.name, user.name)
                          }
                          disabled={resetingUserId === user.id}
                          className="flex items-center gap-2 px-3 py-2 bg-white/10 hover:bg-blue-500/20 text-white/80 hover:text-blue-300 rounded-lg transition-all text-sm"
                        >
                          <RotateCw className={`w-4 h-4 ${resetingUserId === user.id ? 'animate-spin' : ''}`} />
                          Şifre Sıfırla
                        </button>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <div>
            <h4 className="text-2xl font-semibold mb-4 text-white">
              Sistem Logları (Son 50)
            </h4>
            <div className="bg-white/10 border border-white/20 rounded-lg overflow-hidden max-h-96 overflow-y-auto">
              <div className="divide-y divide-white/10">
                {logs.length === 0 ? (
                  <div className="p-4 text-center text-white/40">
                    Log bulunamadı
                  </div>
                ) : (
                  logs.map((log) => (
                    <div key={log.id} className="p-4 hover:bg-white/5 transition-colors">
                      <div className="flex items-start justify-between gap-4">
                        <div className="flex-1">
                          <p className="text-white font-medium text-sm">
                            {log.action_type}
                          </p>
                          <p className="text-white/60 text-sm">{log.details}</p>
                        </div>
                        <span className="text-white/40 text-xs whitespace-nowrap">
                          {new Date(log.timestamp).toLocaleString('tr-TR')}
                        </span>
                      </div>
                    </div>
                  ))
                )}
              </div>
            </div>
          </div>
        </>
      )}
    </div>
  );
}
 

import { useState } from 'react';
import { supabase } from '../App';
import { X } from 'lucide-react';

interface ProfileModalProps {
  user: any;
  onClose: () => void;
}

export default function ProfileModal({ user, onClose }: ProfileModalProps) {
  const [profilePicture, setProfilePicture] = useState<File | null>(null);
  const [isUploading, setIsUploading] = useState(false);
  const [uploadError, setUploadError] = useState('');
  const [uploadSuccess, setUploadSuccess] = useState(false);

  const handleFileSelect = (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (!file) return;

    setUploadError('');
    setUploadSuccess(false);

    if (!file.type.includes('image/jpeg')) {
      setUploadError('Lütfen sadece JPG formatında dosya seçin');
      return;
    }

    if (file.size > 5 * 1024 * 1024) {
      setUploadError('Dosya boyutu 5MB\'dan küçük olmalıdır');
      return;
    }

    setProfilePicture(file);
  };

  const handleUpload = async () => {
    if (!profilePicture) return;

    setIsUploading(true);
    setUploadError('');

    try {
      const filename = `${user.id}-${Date.now()}.jpg`;
      const { error: uploadError } = await supabase.storage
        .from('profile-pictures')
        .upload(filename, profilePicture);

      if (uploadError) throw uploadError;

      const {
        data: { publicUrl },
      } = supabase.storage.from('profile-pictures').getPublicUrl(filename);

      const { error: updateError } = await supabase
        .from('users')
        .update({ profile_picture_url: publicUrl })
        .eq('id', user.id);

      if (updateError) throw updateError;

      setUploadSuccess(true);
      setProfilePicture(null);
      setTimeout(() => {
        setUploadSuccess(false);
      }, 3000);
    } catch (error: any) {
      console.error('Upload error:', error);
      setUploadError(error.message || 'Yükleme sırasında hata oluştu');
    } finally {
      setIsUploading(false);
    }
  };

  return (
    <div className="fixed inset-0 bg-black/50 backdrop-blur-sm flex items-center justify-center z-50">
      <div className="bg-white rounded-2xl p-8 max-w-md w-full mx-4 shadow-2xl">
        <div className="flex items-center justify-between mb-6">
          <h2 className="text-2xl font-bold text-gray-900">Profilim</h2>
          <button
            onClick={onClose}
            className="text-gray-400 hover:text-gray-600 transition-colors"
          >
            <X className="w-6 h-6" />
          </button>
        </div>

        <div className="space-y-6">
          <div>
            <label className="block text-sm font-medium text-gray-700 mb-2">
              Ad Soyad
            </label>
            <input
              type="text"
              value={user.name}
              disabled
              className="w-full px-4 py-3 bg-gray-100 border border-gray-300 rounded-lg text-gray-600 text-lg"
            />
          </div>

          {user.email && (
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-2">
                E-posta
              </label>
              <input
                type="email"
                value={user.email}
                disabled
                className="w-full px-4 py-3 bg-gray-100 border border-gray-300 rounded-lg text-gray-600 text-lg"
              />
            </div>
          )}

          <div>
            <label className="block text-sm font-medium text-gray-700 mb-2">
              Profil Fotoğrafı (JPG sadece)
            </label>
            <input
              type="file"
              accept=".jpg,.jpeg"
              onChange={handleFileSelect}
              className="w-full px-4 py-3 border-2 border-dashed border-gray-300 rounded-lg text-gray-600"
            />
            <p className="text-xs text-gray-500 mt-2">
              Maksimum 5MB, yalnızca JPG formatı
            </p>
          </div>

          {uploadError && (
            <div className="p-4 bg-red-50 border border-red-200 rounded-lg">
              <p className="text-red-700 text-sm">{uploadError}</p>
            </div>
          )}

          {uploadSuccess && (
            <div className="p-4 bg-green-50 border border-green-200 rounded-lg">
              <p className="text-green-700 text-sm">
                Profil fotoğrafı başarıyla yüklendi
              </p>
            </div>
          )}

          <div className="flex gap-4">
            <button
              onClick={onClose}
              className="flex-1 py-3 text-gray-600 font-medium rounded-lg border-2 border-gray-300 hover:bg-gray-50 transition-colors"
            >
              Kapat
            </button>
            {profilePicture && (
              <button
                onClick={handleUpload}
                disabled={isUploading}
                className="flex-1 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 disabled:bg-blue-400 transition-all"
              >
                {isUploading ? 'Yükleniyor...' : 'Yükle'}
              </button>
            )}
          </div>
        </div>
      </div>
    </div>
  );
}


import { useState, useEffect } from 'react';
import { supabase } from '../App';
import { Plus } from 'lucide-react';

interface TaskFormProps {
  onTaskAdded: () => void;
  user: any;
}

export default function TaskForm({ onTaskAdded, user }: TaskFormProps) {
  const [taskText, setTaskText] = useState('');
  const [taskDate, setTaskDate] = useState('');
  const [selectedUsers, setSelectedUsers] = useState<string[]>([]);
  const [teachers, setTeachers] = useState<any[]>([]);
  const [isLoading, setIsLoading] = useState(false);
  const [error, setError] = useState('');

  useEffect(() => {
    loadTeachers();
  }, []);

  const loadTeachers = async () => {
    try {
      const { data, error } = await supabase
        .from('users')
        .select('id, name')
        .eq('role', 'ogretmen');

      if (error) throw error;
      setTeachers(data || []);
    } catch (err) {
      console.error('Error loading teachers:', err);
    }
  };

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    setError('');
    setIsLoading(true);

    try {
      if (!taskText.trim() || !taskDate) {
        setError('Lütfen tüm alanları doldurun');
        setIsLoading(false);
        return;
      }

      const { data: task, error: taskError } = await supabase
        .from('tasks')
        .insert({
          text: taskText.trim(),
          task_date: taskDate,
          created_by_user_id: user.id,
          status: 'pending',
        })
        .select()
        .single();

      if (taskError) throw taskError;

      if (selectedUsers.length > 0) {
        const assignments = selectedUsers.map((userId) => ({
          task_id: task.id,
          user_id: userId,
        }));

        const { error: assignError } = await supabase
          .from('task_assignments')
          .insert(assignments);

        if (assignError) throw assignError;

        for (const userId of selectedUsers) {
          const teacher = teachers.find((t) => t.id === userId);
          const { data: userData } = await supabase
            .from('users')
            .select('email')
            .eq('id', userId)
            .maybeSingle();

          if (userData?.email) {
            try {
              await fetch(
                `${import.meta.env.VITE_SUPABASE_URL}/functions/v1/send_email`,
                {
                  method: 'POST',
                  headers: {
                    'Content-Type': 'application/json',
                    Authorization: `Bearer ${import.meta.env.VITE_SUPABASE_ANON_KEY}`,
                  },
                  body: JSON.stringify({
                    to: userData.email,
                    subject: 'FAHYOMBA - Yeni Görev Atandı',
                    html: `
                      <div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">
                        <h2>Merhaba ${teacher?.name},</h2>
                        <p>Sizin için yeni bir görev atanmıştır:</p>
                        <div style="background-color: #f3f4f6; padding: 16px; border-radius: 8px; margin: 20px 0;">
                          <p><strong>${taskText}</strong></p>
                          <p style="color: #666; font-size: 14px;">Tarih: ${taskDate}</p>
                        </div>
                        <p>Sisteme giriş yaparak görevinizi tamamlayabilirsiniz.</p>
                        <p style="color: #666; font-size: 12px; margin-top: 30px;">FAHYOMBA © 2026</p>
                      </div>
                    `,
                  }),
                }
              );
            } catch (emailError) {
              console.error('Email sending failed:', emailError);
            }
          }
        }
      }

      setTaskText('');
      setTaskDate('');
      setSelectedUsers([]);
      onTaskAdded();
    } catch (err: any) {
      console.error('Error adding task:', err);
      setError(err.message || 'Görev eklenirken hata oluştu');
    } finally {
      setIsLoading(false);
    }
  };

  const toggleUser = (userId: string) => {
    setSelectedUsers((prev) =>
      prev.includes(userId)
        ? prev.filter((id) => id !== userId)
        : [...prev, userId]
    );
  };

  return (
    <div className="bg-white/10 backdrop-blur-2xl rounded-2xl p-8 border border-white/20">
      <div className="flex items-center gap-3 mb-6">
        <div className="px-4 py-2 bg-blue-500/20 text-blue-300 rounded-lg text-sm font-semibold flex items-center gap-2">
          <Plus className="w-4 h-4" />
          YENİ GÖREV
        </div>
        <p className="text-xl font-medium text-white">{user.name}</p>
      </div>

      {error && (
        <div className="mb-6 p-4 bg-red-500/10 border border-red-500/30 rounded-lg">
          <p className="text-red-300 text-sm">{error}</p>
        </div>
      )}

      <form onSubmit={handleSubmit} className="space-y-6">
        <div>
          <label className="block text-sm font-medium text-white/80 mb-2">
            Görev Açıklaması
          </label>
          <textarea
            value={taskText}
            onChange={(e) => setTaskText(e.target.value)}
            rows={3}
            className="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg text-white placeholder-white/40 focus:border-blue-500 focus:outline-none resize-none"
            placeholder="Görev açıklamasını yaz..."
            disabled={isLoading}
          />
        </div>

        <div>
          <label className="block text-sm font-medium text-white/80 mb-3">
            Bu görevi kime atayacaksın?
          </label>
          <div className="grid grid-cols-2 gap-2 max-h-40 overflow-y-auto">
            {teachers.map((teacher) => (
              <label
                key={teacher.id}
                className="flex items-center gap-2 p-2 hover:bg-white/5 rounded-lg cursor-pointer transition-colors"
              >
                <input
                  type="checkbox"
                  checked={selectedUsers.includes(teacher.id)}
                  onChange={() => toggleUser(teacher.id)}
                  disabled={isLoading}
                  className="w-4 h-4 rounded accent-blue-500"
                />
                <span className="text-white/80 text-sm">{teacher.name}</span>
              </label>
            ))}
          </div>
          {teachers.length === 0 && (
            <p className="text-white/40 text-sm py-4 text-center">
              Henüz kayıtlı öğretmen yok
            </p>
          )}
        </div>

        <div className="grid grid-cols-2 gap-4">
          <div>
            <label className="block text-sm font-medium text-white/80 mb-2">
              Tarih
            </label>
            <input
              type="date"
              value={taskDate}
              onChange={(e) => setTaskDate(e.target.value)}
              className="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg text-white focus:border-blue-500 focus:outline-none"
              disabled={isLoading}
            />
          </div>
          <div className="flex items-end">
            <button
              type="submit"
              disabled={isLoading}
              className="w-full bg-blue-600 hover:bg-blue-700 disabled:bg-blue-400 text-white py-3 rounded-lg font-semibold transition-all"
            >
              {isLoading ? 'Ekleniyor...' : 'Göreve Ekle'}
            </button>
          </div>
        </div>
      </form>
    </div>
  );
}


import { useState } from 'react';
import { supabase } from '../App';
import { CheckCircle2, Circle, Upload, Trash2 } from 'lucide-react';

interface TaskListProps {
  tasks: any[];
  user: any;
  onTaskUpdated: () => void;
}

export default function TaskList({ tasks, user, onTaskUpdated }: TaskListProps) {
  const [uploadingTaskId, setUploadingTaskId] = useState<string | null>(null);

  const handleTaskComplete = async (taskId: string) => {
    try {
      const { error } = await supabase
        .from('tasks')
        .update({ status: 'completed' })
        .eq('id', taskId);

      if (error) throw error;

      await supabase.from('activity_logs').insert({
        user_id: user.id,
        action_type: 'Task Completed',
        details: `Görev ID: ${taskId}`,
      });

      onTaskUpdated();
    } catch (error) {
      console.error('Error completing task:', error);
    }
  };

  const handlePhotoUpload = async (taskId: string, file: File) => {
    if (!file.type.startsWith('image/')) {
      alert('Lütfen bir resim dosyası seçin');
      return;
    }

    setUploadingTaskId(taskId);

    try {
      const filename = `${taskId}-${Date.now()}.jpg`;
      const { error: uploadError } = await supabase.storage
        .from('task-photos')
        .upload(filename, file);

      if (uploadError) throw uploadError;

      const {
        data: { publicUrl },
      } = supabase.storage.from('task-photos').getPublicUrl(filename);

      const { error: updateError } = await supabase
        .from('tasks')
        .update({ photo_url: publicUrl })
        .eq('id', taskId);

      if (updateError) throw updateError;

      onTaskUpdated();
    } catch (error) {
      console.error('Error uploading photo:', error);
      alert('Fotoğraf yüklenirken hata oluştu');
    } finally {
      setUploadingTaskId(null);
    }
  };

  const handleDeleteTask = async (taskId: string) => {
    if (!confirm('Bu görevi silmek istediğinden emin misin?')) return;

    try {
      const { error } = await supabase.from('tasks').delete().eq('id', taskId);

      if (error) throw error;

      await supabase.from('activity_logs').insert({
        user_id: user.id,
        action_type: 'Task Deleted',
        details: `Görev ID: ${taskId}`,
      });

      onTaskUpdated();
    } catch (error) {
      console.error('Error deleting task:', error);
    }
  };

  return (
    <div className="bg-white/10 backdrop-blur-2xl rounded-2xl p-8 border border-white/20">
      <h3 className="text-3xl font-semibold mb-6 flex items-center gap-3">
        📋 Görevler
      </h3>

      {tasks.length === 0 ? (
        <div className="text-center py-12">
          <p className="text-white/40 text-lg">Henüz görev yok</p>
        </div>
      ) : (
        <div className="space-y-4 max-h-[600px] overflow-y-auto pr-2">
          {tasks.map((task) => (
            <div
              key={task.id}
              className="bg-white/10 border border-white/20 rounded-lg p-5 hover:bg-white/15 transition-colors"
            >
              <div className="flex items-start justify-between gap-4">
                <div className="flex-1">
                  <p className="text-white font-medium text-lg">{task.text}</p>
                  <p className="text-white/60 text-sm mt-2">
                    📅 {new Date(task.task_date).toLocaleDateString('tr-TR')}
                  </p>
                </div>

                {user.role === 'ogretmen' && (
                  <div className="flex items-center gap-2">
                    <button
                      onClick={() => handleTaskComplete(task.id)}
                      className={`p-2 rounded-lg transition-all ${
                        task.status === 'completed'
                          ? 'bg-green-500/20 text-green-400'
                          : 'bg-white/10 text-white/60 hover:bg-white/20'
                      }`}
                      title={
                        task.status === 'completed'
                          ? 'Tamamlandı'
                          : 'Tamamla'
                      }
                    >
                      {task.status === 'completed' ? (
                        <CheckCircle2 className="w-5 h-5" />
                      ) : (
                        <Circle className="w-5 h-5" />
                      )}
                    </button>

                    <label className="p-2 rounded-lg bg-white/10 text-white/60 hover:bg-white/20 cursor-pointer transition-all">
                      <Upload className="w-5 h-5" />
                      <input
                        type="file"
                        accept="image/*"
                        onChange={(e) => {
                          if (e.target.files?.[0]) {
                            handlePhotoUpload(task.id, e.target.files[0]);
                          }
                        }}
                        className="hidden"
                        disabled={uploadingTaskId === task.id}
                      />
                    </label>
                  </div>
                )}

                {(user.role === 'mudir' || user.role === 'admin') && (
                  <button
                    onClick={() => handleDeleteTask(task.id)}
                    className="p-2 rounded-lg bg-white/10 text-white/60 hover:bg-red-500/20 hover:text-red-400 transition-all"
                    title="Sil"
                  >
                    <Trash2 className="w-5 h-5" />
                  </button>
                )}
              </div>

              {task.photo_url && (
                <div className="mt-4">
                  <img
                    src={task.photo_url}
                    alt="Tamamlanan görev"
                    className="max-w-xs rounded-lg"
                  />
                </div>
              )}

              {task.status === 'completed' && (
                <div className="mt-3 inline-block px-3 py-1 bg-green-500/20 text-green-400 text-xs rounded-full font-medium">
                  ✓ Tamamlandı
                </div>
              )}
            </div>
          ))}
        </div>
      )}
    </div>
  );
}


import { useEffect, useState } from 'react';
import { supabase } from '../App';
import { Users } from 'lucide-react';

export default function TeacherRoster() {
  const [teachers, setTeachers] = useState<any[]>([]);
  const [isLoading, setIsLoading] = useState(true);

  useEffect(() => {
    loadTeachers();

    const subscription = supabase
      .from('teacher_roster')
      .on('*', () => {
        loadTeachers();
      })
      .subscribe();

    return () => {
      subscription.unsubscribe();
    };
  }, []);

  const loadTeachers = async () => {
    try {
      const { data, error } = await supabase
        .from('teacher_roster')
        .select('*')
        .order('added_at', { ascending: false });

      if (error) throw error;
      setTeachers(data || []);
    } catch (error) {
      console.error('Error loading teacher roster:', error);
    } finally {
      setIsLoading(false);
    }
  };

  return (
    <div className="bg-white/10 backdrop-blur-2xl rounded-2xl p-8 border border-white/20">
      <h3 className="text-3xl font-semibold mb-6 flex items-center gap-3">
        <Users className="w-8 h-8" />
        Öğretmen Listesi
      </h3>

      {isLoading ? (
        <div className="text-center py-8">
          <div className="inline-block w-8 h-8 border-4 border-slate-600 border-t-blue-500 rounded-full animate-spin"></div>
        </div>
      ) : teachers.length === 0 ? (
        <p className="text-white/40 text-center py-8">
          Henüz kayıtlı öğretmen yok
        </p>
      ) : (
        <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {teachers.map((teacher) => (
            <div
              key={teacher.id}
              className="bg-white/10 border border-white/20 rounded-lg p-4 hover:bg-white/15 transition-colors"
            >
              <p className="text-white font-medium">{teacher.name}</p>
              <p className="text-white/60 text-sm mt-2">
                📅{' '}
                {new Date(teacher.added_at).toLocaleDateString('tr-TR', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </p>
            </div>
          ))}
        </div>
      )}
    </div>
  );
}

import { useEffect, useState } from 'react';
import { createClient } from '@supabase/supabase-js';
import RolePage from './pages/RolePage';
import AuthPage from './pages/AuthPage';
import Dashboard from './pages/Dashboard';

const supabaseUrl = import.meta.env.VITE_SUPABASE_URL;
const supabaseKey = import.meta.env.VITE_SUPABASE_ANON_KEY;

export const supabase = createClient(supabaseUrl, supabaseKey);

type CurrentPage = 'role' | 'auth' | 'dashboard';

interface CurrentUser {
  id?: string;
  name: string;
  email?: string;
  role: 'admin' | 'mudir' | 'ogretmen';
}

function App() {
  const [currentPage, setCurrentPage] = useState<CurrentPage>('role');
  const [currentUser, setCurrentUser] = useState<CurrentUser | null>(null);
  const [selectedRole, setSelectedRole] = useState<string | null>(null);
  const [isLoading, setIsLoading] = useState(true);

  useEffect(() => {
    checkPersistentLogin();
  }, []);

  const checkPersistentLogin = async () => {
    const stored = localStorage.getItem('fahyomba_user');
    if (stored) {
      try {
        const user = JSON.parse(stored);
        setCurrentUser(user);
        setCurrentPage('dashboard');
      } catch (error) {
        console.error('Error parsing stored user:', error);
        localStorage.removeItem('fahyomba_user');
      }
    }
    setIsLoading(false);
  };

  const handleSelectRole = (role: string) => {
    setSelectedRole(role);
    setCurrentPage('auth');
  };

  const handleBackToRole = () => {
    setSelectedRole(null);
    setCurrentPage('role');
  };

  const handleLogin = (user: CurrentUser) => {
    setCurrentUser(user);
    localStorage.setItem('fahyomba_user', JSON.stringify(user));
    setCurrentPage('dashboard');
  };

  const handleLogout = () => {
    setCurrentUser(null);
    setSelectedRole(null);
    localStorage.removeItem('fahyomba_user');
    setCurrentPage('role');
  };

  if (isLoading) {
    return (
      <div className="min-h-screen bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 flex items-center justify-center">
        <div className="text-center">
          <div className="inline-block">
            <div className="w-12 h-12 border-4 border-slate-600 border-t-blue-500 rounded-full animate-spin"></div>
          </div>
          <p className="text-white/60 mt-4 font-medium">FAHYOMBA Yükleniyor...</p>
        </div>
      </div>
    );
  }

  return (
    <>
      {currentPage === 'role' && <RolePage onSelectRole={handleSelectRole} />}
      {currentPage === 'auth' && selectedRole && (
        <AuthPage
          role={selectedRole}
          onBack={handleBackToRole}
          onLogin={handleLogin}
        />
      )}
      {currentPage === 'dashboard' && currentUser && (
        <Dashboard user={currentUser} onLogout={handleLogout} />
      )}
    </>
  );
}

export default App;

